# =============================================================================
# SourceNest Frontend (Next.js)
# Copy to .env.local for local dev, or set in your hosting platform for production.
# Only NEXT_PUBLIC_* variables are exposed to the browser — never put secrets here.
# =============================================================================

# Laravel API base URL (must include /api/v1)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Google Sign-In (public client ID only — secret stays on the Laravel API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# PayPal (public client ID only — secret stays on the Laravel API)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Pusher / Laravel Echo (public key + cluster only)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# -----------------------------------------------------------------------------
# Production example:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
# NEXT_PUBLIC_PUSHER_KEY=your_pusher_key
# NEXT_PUBLIC_PUSHER_CLUSTER=ap2
